# Local Development Environment
APP_ENV=local
DEBUG=true
LOG_LEVEL=DEBUG

{% if cookiecutter.db_driver == "postgresql" -%}
# PostgreSQL Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME={{ cookiecutter.project_slug }}
DB_USER=postgres
DB_PASSWORD=postgres
{%- else -%}
# SQLite Database (auto-configured)
# No additional database config needed for local SQLite
{%- endif %}
